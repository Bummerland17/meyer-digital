{
  "template_id": "split-problem-solution",
  "name": "Split Problem / Solution",
  "description": "Screen splits vertically: red problem side (left) slams in first, green solution side (right) slides in and takes over. High drama, fast pace. Perfect for PantryMate food waste angle and SmartBook missed calls angle.",
  "format": "9:16",
  "dimensions": "1080x1920",
  "duration": "auto",
  "fps": 30,

  "brand_colors": {
    "PantryMate":    { "bg": "#1a3a2a", "accent": "#4ade80", "problem_bg": "#7f1d1d", "solution_bg": "#14532d" },
    "SmartBook AI":  { "bg": "#0d1521", "accent": "#3b82f6", "problem_bg": "#1e1b4b", "solution_bg": "#0d1521" },
    "UnitFix":       { "bg": "#1a1a2e", "accent": "#f59e0b", "problem_bg": "#292524", "solution_bg": "#1a1a2e" }
  },

  "creatomate_spec": {
    "source": {
      "output_format": "mp4",
      "width": 1080,
      "height": 1920,
      "frame_rate": 30,
      "duration": "auto",
      "elements": [

        {
          "id": "problem_panel",
          "type": "rectangle",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "100%",
          "fill_color": "{{problem_bg}}",
          "z_index": 1,
          "animations": [
            {
              "type": "slide-in",
              "direction": "left",
              "start": 0.0,
              "duration": 0.3,
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
            },
            {
              "type": "width",
              "value_from": "100%",
              "value_to": "50%",
              "start": "{{split_start}}",
              "duration": 0.4,
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
            }
          ]
        },

        {
          "id": "problem_label",
          "type": "text",
          "text": "THE PROBLEM",
          "x": "4%", "y": "8%",
          "width": "46%",
          "font_family": "Montserrat",
          "font_weight": "900",
          "font_size": "32px",
          "fill_color": "#ef4444",
          "letter_spacing": "3px",
          "z_index": 10,
          "animations": [{ "type": "fade-in", "start": 0.3, "duration": 0.2 }]
        },

        {
          "id": "problem_icon",
          "type": "text",
          "text": "❌",
          "x": "4%", "y": "14%",
          "font_size": "80px",
          "z_index": 10,
          "animations": [
            {
              "type": "scale",
              "value_from": 0, "value_to": 1,
              "start": 0.4, "duration": 0.3,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
            }
          ]
        },

        {
          "id": "problem_headline",
          "type": "text",
          "text": "{{problem_headline}}",
          "x": "4%", "y": "26%",
          "width": "46%",
          "font_family": "Montserrat",
          "font_weight": "800",
          "font_size": "52px",
          "line_height": 1.15,
          "fill_color": "#ffffff",
          "text_transform": "uppercase",
          "z_index": 10,
          "animations": [
            {
              "type": "text-appear",
              "split": "word",
              "duration": 0.07,
              "start": 0.5
            }
          ]
        },

        {
          "id": "problem_stat",
          "type": "text",
          "text": "{{problem_stat}}",
          "x": "4%", "y": "54%",
          "width": "44%",
          "font_family": "Inter",
          "font_weight": "600",
          "font_size": "34px",
          "line_height": 1.3,
          "fill_color": "#fca5a5",
          "z_index": 10,
          "animations": [{ "type": "fade-in", "start": "{{problem_stat_start}}", "duration": 0.25 }]
        },

        {
          "id": "divider",
          "type": "rectangle",
          "x": "50%", "y": "0%",
          "width": "4px", "height": "100%",
          "fill_color": "#ffffff",
          "opacity": 0.15,
          "z_index": 15,
          "animations": [
            {
              "type": "fade-in",
              "start": "{{split_start}}",
              "duration": 0.2
            }
          ]
        },

        {
          "id": "solution_panel",
          "type": "rectangle",
          "x": "50%", "y": "0%",
          "width": "50%", "height": "100%",
          "fill_color": "{{solution_bg}}",
          "z_index": 2,
          "animations": [
            {
              "type": "slide-in",
              "direction": "right",
              "start": "{{split_start}}",
              "duration": 0.4,
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
            }
          ]
        },

        {
          "id": "solution_label",
          "type": "text",
          "text": "THE FIX",
          "x": "52%", "y": "8%",
          "width": "46%",
          "font_family": "Montserrat",
          "font_weight": "900",
          "font_size": "32px",
          "fill_color": "{{accent_color}}",
          "letter_spacing": "3px",
          "z_index": 10,
          "animations": [{ "type": "fade-in", "start": "{{split_start_plus}}", "duration": 0.2 }]
        },

        {
          "id": "solution_icon",
          "type": "text",
          "text": "✅",
          "x": "52%", "y": "14%",
          "font_size": "80px",
          "z_index": 10,
          "animations": [
            {
              "type": "scale",
              "value_from": 0, "value_to": 1,
              "start": "{{split_start_plus}}",
              "duration": 0.3,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
            }
          ]
        },

        {
          "id": "solution_headline",
          "type": "text",
          "text": "{{solution_headline}}",
          "x": "52%", "y": "26%",
          "width": "46%",
          "font_family": "Montserrat",
          "font_weight": "800",
          "font_size": "52px",
          "line_height": 1.15,
          "fill_color": "#ffffff",
          "text_transform": "uppercase",
          "z_index": 10,
          "animations": [
            {
              "type": "text-appear",
              "split": "word",
              "duration": 0.07,
              "start": "{{solution_text_start}}"
            }
          ]
        },

        {
          "id": "solution_detail",
          "type": "text",
          "text": "{{solution_detail}}",
          "x": "52%", "y": "54%",
          "width": "44%",
          "font_family": "Inter",
          "font_weight": "600",
          "font_size": "34px",
          "line_height": 1.3,
          "fill_color": "{{accent_color}}",
          "z_index": 10,
          "animations": [{ "type": "fade-in", "start": "{{solution_detail_start}}", "duration": 0.25 }]
        },

        {
          "id": "cta_full_width",
          "type": "rectangle",
          "x": "0%", "y": "85%",
          "width": "100%", "height": "100px",
          "fill_color": "{{accent_color}}",
          "z_index": 20,
          "animations": [
            {
              "type": "slide-in",
              "direction": "bottom",
              "start": "{{cta_start}}",
              "duration": 0.35,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
            }
          ]
        },

        {
          "id": "cta_text",
          "type": "text",
          "text": "{{cta_text}}",
          "x": "0%", "y": "85%",
          "width": "100%", "height": "100px",
          "font_family": "Montserrat",
          "font_weight": "800",
          "font_size": "36px",
          "fill_color": "#000000",
          "text_align": "center",
          "vertical_align": "middle",
          "z_index": 21,
          "animations": [{ "type": "fade-in", "start": "{{cta_text_start}}", "duration": 0.2 }]
        },

        {
          "id": "voiceover",
          "type": "audio",
          "source": "{{voiceover_url}}",
          "z_index": 30,
          "volume": 1.0
        }
      ]
    }
  },

  "variables": {
    "problem_bg":           "Dark red: #7f1d1d (PantryMate) or product-specific",
    "solution_bg":          "Product bg color",
    "accent_color":         "Product accent color",
    "problem_headline":     "Short, punchy problem (max 5 words, uppercase)",
    "problem_stat":         "Specific stat or pain-point detail",
    "problem_stat_start":   "Timing offset in seconds (approx 2.0)",
    "solution_headline":    "Short fix statement (max 5 words)",
    "solution_detail":      "How product solves it (1-2 lines)",
    "cta_text":             "Single action statement",
    "split_start":          "When screen splits (approx 3.5)",
    "split_start_plus":     "split_start + 0.4",
    "solution_text_start":  "split_start + 0.6",
    "solution_detail_start":"split_start + 1.2",
    "cta_start":            "Total_duration - 5",
    "cta_text_start":       "cta_start + 0.3",
    "voiceover_url":        "ElevenLabs MP3 URL or local path"
  },

  "copy_examples": {
    "PantryMate": {
      "problem_headline": "FOOD ROTTING\nIN YOUR FRIDGE",
      "problem_stat": "$1,500/year\nthrown in the trash",
      "solution_headline": "COOK WHAT\nYOU HAVE",
      "solution_detail": "PantryMate tells you\nwhat to make in 30s",
      "cta_text": "Free on App Store → pantrymate.net"
    },
    "SmartBook AI": {
      "problem_headline": "CALL AT 7PM.\nNO ANSWER.",
      "problem_stat": "They book your\ncompetitor instead",
      "solution_headline": "AI ANSWERS\n24/7",
      "solution_detail": "Books them live.\nYou get the notification.",
      "cta_text": "smartbookai.com — try free"
    }
  }
}
