{
  "template_id": "bold-text-hook",
  "name": "Bold Text Hook",
  "description": "Dark background, word-by-word white text animation, voiceover synced. Proven viral TikTok/Reels format. Hook stops the scroll; body builds fast; CTA is unmissable.",
  "format": "9:16",
  "dimensions": "1080x1920",
  "duration": "auto",
  "fps": 30,

  "brand_colors": {
    "PantryMate":    { "bg": "#1a3a2a", "accent": "#4ade80", "text": "#ffffff" },
    "SmartBook AI":  { "bg": "#0d1521", "accent": "#3b82f6", "text": "#ffffff" },
    "UnitFix":       { "bg": "#1a1a2e", "accent": "#f59e0b", "text": "#ffffff" }
  },

  "creatomate_spec": {
    "source": {
      "output_format": "mp4",
      "width": 1080,
      "height": 1920,
      "frame_rate": 30,
      "duration": "auto",
      "elements": [

        {
          "id": "background",
          "type": "rectangle",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "100%",
          "fill_color": "{{bg_color}}",
          "z_index": 0
        },

        {
          "id": "noise_overlay",
          "type": "image",
          "source": "data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciPjxmaWx0ZXIgaWQ9Im4iPjxmZVR1cmJ1bGVuY2UgdHlwZT0iZnJhY3RhbE5vaXNlIiBiYXNlRnJlcXVlbmN5PSIwLjgiIG51bU9jdGF2ZXM9IjQiLz48L2ZpbHRlcj48cmVjdCB3aWR0aD0iMTAwJSIgaGVpZ2h0PSIxMDAlIiBmaWx0ZXI9InVybCgjbikiIG9wYWNpdHk9IjAuMDUiLz48L3N2Zz4=",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "100%",
          "opacity": 0.04,
          "z_index": 1
        },

        {
          "id": "accent_bar_top",
          "type": "rectangle",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "8px",
          "fill_color": "{{accent_color}}",
          "z_index": 2
        },

        {
          "id": "accent_bar_bottom",
          "type": "rectangle",
          "x": "0%", "y": "calc(100% - 8px)",
          "width": "100%", "height": "8px",
          "fill_color": "{{accent_color}}",
          "z_index": 2
        },

        {
          "id": "hook_text",
          "type": "text",
          "text": "{{hook_text}}",
          "x": "8%", "y": "22%",
          "width": "84%",
          "font_family": "Montserrat",
          "font_weight": "900",
          "font_size": "72px",
          "line_height": 1.1,
          "fill_color": "#ffffff",
          "text_transform": "uppercase",
          "letter_spacing": "-1px",
          "z_index": 10,
          "animations": [
            {
              "type": "text-appear",
              "split": "word",
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)",
              "duration": 0.08,
              "start": 0.0,
              "color_from": "{{accent_color}}",
              "color_to": "#ffffff"
            }
          ]
        },

        {
          "id": "hook_accent_line",
          "type": "rectangle",
          "x": "8%", "y": "calc({{hook_text_bottom}} + 12px)",
          "width": "0%", "height": "4px",
          "fill_color": "{{accent_color}}",
          "z_index": 9,
          "animations": [
            {
              "type": "width",
              "value_from": "0%",
              "value_to": "84%",
              "start": 0.5,
              "duration": 0.4,
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
            }
          ]
        },

        {
          "id": "body_text",
          "type": "text",
          "text": "{{body_text}}",
          "x": "8%", "y": "52%",
          "width": "84%",
          "font_family": "Inter",
          "font_weight": "600",
          "font_size": "42px",
          "line_height": 1.35,
          "fill_color": "#e8e8e8",
          "z_index": 10,
          "animations": [
            {
              "type": "text-appear",
              "split": "word",
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)",
              "duration": 0.06,
              "start": "{{hook_duration}}",
              "fade_in_duration": 0.15
            }
          ]
        },

        {
          "id": "cta_box",
          "type": "rectangle",
          "x": "8%", "y": "80%",
          "width": "84%", "height": "120px",
          "fill_color": "{{accent_color}}",
          "border_radius": "16px",
          "z_index": 9,
          "animations": [
            {
              "type": "scale",
              "value_from": 0,
              "value_to": 1,
              "start": "{{cta_start}}",
              "duration": 0.35,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
            }
          ]
        },

        {
          "id": "cta_text",
          "type": "text",
          "text": "{{cta_text}}",
          "x": "8%", "y": "80%",
          "width": "84%", "height": "120px",
          "font_family": "Montserrat",
          "font_weight": "800",
          "font_size": "38px",
          "fill_color": "#000000",
          "text_align": "center",
          "vertical_align": "middle",
          "z_index": 11,
          "animations": [
            {
              "type": "fade-in",
              "start": "{{cta_start_plus}}",
              "duration": 0.2
            }
          ]
        },

        {
          "id": "brand_tag",
          "type": "text",
          "text": "{{brand_name}}",
          "x": "8%", "y": "91%",
          "width": "84%",
          "font_family": "Inter",
          "font_weight": "400",
          "font_size": "28px",
          "fill_color": "{{accent_color}}",
          "opacity": 0.7,
          "text_align": "center",
          "z_index": 10
        },

        {
          "id": "voiceover",
          "type": "audio",
          "source": "{{voiceover_url}}",
          "z_index": 20,
          "volume": 1.0
        }
      ]
    }
  },

  "variables": {
    "bg_color":       "Product bg color from brand_colors",
    "accent_color":   "Product accent color from brand_colors",
    "hook_text":      "HOOK section text (all caps, max 8 words)",
    "body_text":      "BODY section — key insight, 2-3 short sentences",
    "cta_text":       "CTA — single action (e.g. 'Try Free Today')",
    "brand_name":     "e.g. 'pantrymate.net' or '@smartbookai'",
    "hook_duration":  "Seconds of hook (typically 3.0)",
    "cta_start":      "When CTA box appears (typically duration - 6)",
    "cta_start_plus": "cta_start + 0.2",
    "voiceover_url":  "ElevenLabs MP3 URL or local path"
  },

  "usage_notes": [
    "Hook text should be max 8 words — one strong punch",
    "Word-by-word animation fires at voiceover pace — time start offsets to match",
    "Body text: keep sentences short, max 15 words each",
    "CTA box color = accent, text color = black (always readable)",
    "Export at H.264, AAC audio, for TikTok + IG compatibility",
    "Add captions via TikTok auto-caption or CapCut — do not bake in at render"
  ]
}
