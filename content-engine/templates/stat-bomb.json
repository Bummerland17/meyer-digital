{
  "template_id": "stat-bomb",
  "name": "Stat Bomb",
  "description": "Shocking stat slams in huge — screen shakes — countdown ticker runs — solution reveals. High-contrast minimal design. Works for any product with a compelling number. Stops scroll in 1 second flat.",
  "format": "9:16",
  "dimensions": "1080x1920",
  "duration": "auto",
  "fps": 30,

  "brand_colors": {
    "PantryMate":    { "bg": "#1a3a2a", "accent": "#4ade80", "stat_color": "#ffffff", "counter_color": "#4ade80" },
    "SmartBook AI":  { "bg": "#0d1521", "accent": "#3b82f6", "stat_color": "#ffffff", "counter_color": "#3b82f6" },
    "UnitFix":       { "bg": "#1a1a2e", "accent": "#f59e0b", "stat_color": "#ffffff", "counter_color": "#f59e0b" }
  },

  "creatomate_spec": {
    "source": {
      "output_format": "mp4",
      "width": 1080,
      "height": 1920,
      "frame_rate": 30,
      "duration": "auto",
      "elements": [

        {
          "id": "background",
          "type": "rectangle",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "100%",
          "fill_color": "{{bg_color}}",
          "z_index": 0
        },

        {
          "id": "flash_overlay",
          "type": "rectangle",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "100%",
          "fill_color": "#ffffff",
          "opacity": 0,
          "z_index": 50,
          "animations": [
            {
              "type": "opacity",
              "value_from": 0.9,
              "value_to": 0,
              "start": 0.0,
              "duration": 0.25,
              "easing": "ease-out"
            }
          ]
        },

        {
          "id": "pre_hook_text",
          "type": "text",
          "text": "{{pre_hook}}",
          "x": "8%", "y": "12%",
          "width": "84%",
          "font_family": "Inter",
          "font_weight": "500",
          "font_size": "38px",
          "line_height": 1.3,
          "fill_color": "#aaaaaa",
          "text_align": "center",
          "z_index": 10,
          "animations": [
            {
              "type": "fade-in",
              "start": 0.25,
              "duration": 0.3
            }
          ]
        },

        {
          "id": "stat_number",
          "type": "text",
          "text": "{{stat_number}}",
          "x": "4%", "y": "28%",
          "width": "92%",
          "font_family": "Montserrat",
          "font_weight": "900",
          "font_size": "180px",
          "line_height": 0.95,
          "fill_color": "{{stat_color}}",
          "text_align": "center",
          "letter_spacing": "-4px",
          "z_index": 10,
          "animations": [
            {
              "type": "scale",
              "value_from": 2.5,
              "value_to": 1,
              "start": 0.5,
              "duration": 0.4,
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
            },
            {
              "type": "opacity",
              "value_from": 0,
              "value_to": 1,
              "start": 0.5,
              "duration": 0.2
            }
          ]
        },

        {
          "id": "stat_label",
          "type": "text",
          "text": "{{stat_label}}",
          "x": "8%", "y": "58%",
          "width": "84%",
          "font_family": "Montserrat",
          "font_weight": "700",
          "font_size": "54px",
          "line_height": 1.2,
          "fill_color": "{{accent_color}}",
          "text_align": "center",
          "text_transform": "uppercase",
          "letter_spacing": "1px",
          "z_index": 10,
          "animations": [
            {
              "type": "text-appear",
              "split": "word",
              "duration": 0.08,
              "start": 0.9
            }
          ]
        },

        {
          "id": "shake_effect",
          "type": "rectangle",
          "x": "0%", "y": "0%",
          "width": "100%", "height": "100%",
          "fill_color": "transparent",
          "z_index": 5,
          "animations": [
            {
              "type": "position",
              "keyframes": [
                { "time": 0.5, "x": "0%" },
                { "time": 0.53, "x": "1.5%" },
                { "time": 0.56, "x": "-1.5%" },
                { "time": 0.59, "x": "1%" },
                { "time": 0.62, "x": "-0.5%" },
                { "time": 0.65, "x": "0%" }
              ]
            }
          ]
        },

        {
          "id": "divider_line",
          "type": "rectangle",
          "x": "8%", "y": "72%",
          "width": "0%", "height": "3px",
          "fill_color": "{{accent_color}}",
          "z_index": 9,
          "animations": [
            {
              "type": "width",
              "value_from": "0%",
              "value_to": "84%",
              "start": 1.8,
              "duration": 0.4,
              "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
            }
          ]
        },

        {
          "id": "solution_reveal",
          "type": "text",
          "text": "{{solution_text}}",
          "x": "8%", "y": "74%",
          "width": "84%",
          "font_family": "Inter",
          "font_weight": "600",
          "font_size": "44px",
          "line_height": 1.35,
          "fill_color": "#ffffff",
          "text_align": "center",
          "z_index": 10,
          "animations": [
            {
              "type": "text-appear",
              "split": "word",
              "duration": 0.07,
              "start": 2.2
            }
          ]
        },

        {
          "id": "cta_pill",
          "type": "rectangle",
          "x": "15%", "y": "88%",
          "width": "70%", "height": "90px",
          "fill_color": "{{accent_color}}",
          "border_radius": "50px",
          "z_index": 20,
          "animations": [
            {
              "type": "scale",
              "value_from": 0,
              "value_to": 1,
              "start": "{{cta_start}}",
              "duration": 0.4,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
            }
          ]
        },

        {
          "id": "cta_text",
          "type": "text",
          "text": "{{cta_text}}",
          "x": "15%", "y": "88%",
          "width": "70%", "height": "90px",
          "font_family": "Montserrat",
          "font_weight": "800",
          "font_size": "32px",
          "fill_color": "#000000",
          "text_align": "center",
          "vertical_align": "middle",
          "z_index": 21,
          "animations": [
            {
              "type": "fade-in",
              "start": "{{cta_text_start}}",
              "duration": 0.2
            }
          ]
        },

        {
          "id": "voiceover",
          "type": "audio",
          "source": "{{voiceover_url}}",
          "z_index": 30,
          "volume": 1.0
        }
      ]
    }
  },

  "variables": {
    "bg_color":      "Product bg from brand_colors",
    "accent_color":  "Product accent from brand_colors",
    "stat_color":    "Always #ffffff for max contrast",
    "pre_hook":      "Short setup line before stat (e.g. 'The average family...')",
    "stat_number":   "THE BIG NUMBER — e.g. '$1,500' or '73%' or '4 hrs'",
    "stat_label":    "What the number means (e.g. 'wasted on food every year')",
    "solution_text": "How your product fixes it (1-2 punchy lines)",
    "cta_text":      "Single action (e.g. 'Fix It Free → pantrymate.net')",
    "cta_start":     "duration - 5 seconds",
    "cta_text_start":"cta_start + 0.35"
  },

  "copy_examples": {
    "PantryMate": {
      "pre_hook": "The average family throws away...",
      "stat_number": "$1,500",
      "stat_label": "wasted on food every single year",
      "solution_text": "PantryMate tells you what to cook\nwith what's already in your fridge.",
      "cta_text": "Free Download → pantrymate.net"
    },
    "SmartBook AI": {
      "pre_hook": "Every missed call after 6pm costs you...",
      "stat_number": "$500",
      "stat_label": "in lost bookings — per night",
      "solution_text": "SmartBook AI answers your phone 24/7\nand books them while you sleep.",
      "cta_text": "See It Live → smartbookai.com"
    },
    "UnitFix": {
      "pre_hook": "Being a landlord takes...",
      "stat_number": "47 hrs",
      "stat_label": "per month on maintenance chaos",
      "solution_text": "UnitFix cuts that to under 10 hours.\nYour tenants self-serve. You get alerts.",
      "cta_text": "Try Free → unitfix.com"
    }
  }
}
